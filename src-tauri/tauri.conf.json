{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Storage Goblin",
  "version": "0.2.0",
  "identifier": "com.storage-goblin",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1432",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Storage Goblin",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "dialog": null
  }
}
